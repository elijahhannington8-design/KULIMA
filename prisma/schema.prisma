// Kulima Platform Database Schema
// Multi-Role Agricultural Ecosystem Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

// User Role Types (for reference, not stored directly on User)
enum Role {
  FARMER
  BUYER
  SUPPLIER
  ADMIN
}

// Supplier Categories
enum SupplierType {
  SEED
  FERTILIZER
  EQUIPMENT
  IRRIGATION
  AGROCHEMICAL
  LIVESTOCK_FEED
}

// Admin Permission Levels
enum AdminRole {
  SUPER_ADMIN
  MODERATOR
  SUPPORT
}

// Existing Enums
enum CropCycleStatus {
  PLANNED
  ACTIVE
  HARVESTED
  FAILED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum NotificationType {
  OFFER_RECEIVED
  OFFER_ACCEPTED
  OFFER_REJECTED
  PRICE_ALERT
  WEATHER_ALERT
  ORDER_PLACED
  ORDER_SHIPPED
  VERIFICATION_APPROVED
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum LoanStatus {
  PENDING
  APPROVED
  DISBURSED
  REPAID
  DEFAULTED
}

// ============================================================================
// CORE USER MODEL
// ============================================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  phoneNumber  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Multi-Role Relationships (Optional - user can have 0 or more roles)
  farmer        Farmer?
  buyer         Buyer?
  supplier      Supplier?
  admin         Admin?
  
  // Shared Relationships
  notifications Notification[]

  @@index([email])
}

// ============================================================================
// ROLE PROFILE MODELS
// ============================================================================

model Farmer {
  id         String   @id @default(cuid())
  userId     String   @unique
  fullName   String
  location   String
  nationalId String?
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  farms       Farm[]
  listings    Listing[]
  loanProfile LoanProfile?

  @@index([userId])
  @@index([verified])
}

model Buyer {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  businessType String
  location     String
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relationships
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  offers Offer[]

  @@index([userId])
  @@index([verified])
}

model Supplier {
  id              String       @id @default(cuid())
  userId          String       @unique
  businessName    String
  supplierType    SupplierType
  location        String
  businessLicense String?
  verified        Boolean      @default(false)
  verifiedAt      DateTime?
  rating          Float?       @default(0)
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relationships
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  products SupplierProduct[]
  orders   SupplierOrder[]

  @@index([userId])
  @@index([supplierType])
  @@index([verified])
}

model Admin {
  id        String    @id @default(cuid())
  userId    String    @unique
  adminRole AdminRole @default(MODERATOR)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminRole])
}

// ============================================================================
// SUPPLIER ECOSYSTEM MODELS
// ============================================================================

model SupplierProduct {
  id          String   @id @default(cuid())
  supplierId  String
  name        String
  description String?
  category    String
  price       Float
  unit        String
  stock       Int
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  supplier Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  orders   SupplierOrder[]

  @@index([supplierId])
  @@index([active])
  @@index([category])
}

model SupplierOrder {
  id         String      @id @default(cuid())
  supplierId String
  buyerId    String
  productId  String
  quantity   Int
  totalPrice Float
  status     OrderStatus @default(PENDING)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  // Relationships
  supplier Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  SupplierProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([buyerId])
  @@index([productId])
  @@index([status])
}

// ============================================================================
// EXISTING FARMER ECOSYSTEM MODELS (Unchanged)
// ============================================================================

model Farm {
  id          String   @id @default(cuid())
  farmerId    String
  name        String
  location    String
  sizeInAcres Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  farmer     Farmer      @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  cropCycles CropCycle[]

  @@index([farmerId])
}

model CropCycle {
  id                  String           @id @default(cuid())
  farmId              String
  cropType            String
  plantingDate        DateTime
  expectedHarvestDate DateTime
  actualHarvestDate   DateTime?
  status              CropCycleStatus
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // Relationships
  farm Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId])
  @@index([status])
}

model Listing {
  id           String        @id @default(cuid())
  farmerId     String
  cropType     String
  quantity     Float
  pricePerUnit Float
  status       ListingStatus
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  // Relationships
  farmer Farmer  @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  offers Offer[]

  @@index([farmerId])
  @@index([status])
  @@index([farmerId, status])
}

model Offer {
  id          String      @id @default(cuid())
  listingId   String
  buyerId     String
  offerAmount Float
  status      OfferStatus
  message     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relationships
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   Buyer   @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([buyerId])
  @@index([status])
}

model Notification {
  id        String             @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel
  message   String
  status    NotificationStatus
  sentAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  // Relationships
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model MarketPrice {
  id           String   @id @default(cuid())
  cropType     String
  pricePerUnit Float
  location     String
  date         DateTime
  source       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([location])
  @@index([cropType, location, date])
}

model LoanProfile {
  id               String    @id @default(cuid())
  farmerId         String    @unique
  loanAmount       Float
  interestRate     Float
  status           LoanStatus
  disbursementDate DateTime?
  repaymentDate    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relationships
  farmer Farmer @relation(fields: [farmerId], references: [id], onDelete: Cascade)

  @@index([farmerId])
  @@index([status])
}
